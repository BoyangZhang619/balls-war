<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="6.0.0" />
  </ItemGroup>

  <Target Name="CopyRaylibNative" AfterTargets="Build">
    <Copy SourceFiles="$(NuGetPackageRoot)raylib-cs\6.0.0\runtimes\win-x64\native\raylib.dll"
          DestinationFolder="$(OutputPath)"
          Condition="Exists('$(NuGetPackageRoot)raylib-cs\6.0.0\runtimes\win-x64\native\raylib.dll')"
          SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <ProjectReference Include="..\BallsWar.Core\BallsWar.Core.csproj" />
  </ItemGroup>

</Project>
